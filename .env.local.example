# Supabase — lấy từ Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service role key (CHỈ dùng server-side, không bao giờ expose ra client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL gốc của site (dùng cho OAuth redirect, metadata, sitemap), ví dụ http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Đăng ký tài khoản mới — mặc định tắt. Đặt `true` để mở lại.
# SIGNUP_ENABLED=true

# (Tùy chọn) Upstash Redis cho rate-limit chia sẻ giữa các instance (/api/track, /api/auth/username).
# Bỏ trống → tự fallback rate-limit in-memory per-instance (đủ cho dev). Lấy từ console.upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
